int *Dijkstra(int *graph, int n) {

    int *distance = (int*)malloc(n*sizeof(int));
    int *visit = (int*)malloc(n*sizeof(int));

    int i, j, u;
    int smallest;

    for(i = 0; i < n; i++) {
        visit[i] = 1;
        distance[i] = graph[i];

        if(graph[i] == -1)
            distance[i] = 100;
    }

    distance[0] = 0;
    visit[0] = 0;

    for(i = 1; i < n-1; i++) {

        smallest = 100;

        for(j = 0; j < n; j++) {
            if(visit[j] && distance[j] < smallest) {
                smallest = distance[j];
                u = j;
            }
        }

        visit[u] = 0;

        for(j = 0; j < n; j++) {
            if(visit[j] && graph[u*n + j] != -1) {
                if(distance[u] + graph[u*n + j] < distance[j]) {
                    distance[j] = distance[u] + graph[u*n + j];
                }
            }
        }
    }

    free(visit);
    return distance;
}
